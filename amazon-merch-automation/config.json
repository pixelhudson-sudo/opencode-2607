{
  "ai": {
    "provider": "openai",
    "model": "gpt-3.5-turbo",
    "api_key_env": "OPENAI_API_KEY",
    "max_tokens": 2000,
    "temperature": 0.7,
    "endpoint": "https://api.openai.com/v1/chat/completions"
  },
  "scraper": {
    "delay_min_seconds": 2.0,
    "delay_max_seconds": 5.0,
    "max_pages_per_search": 3
  },
  "pricing": {
    "default_standard_tee": 19.99,
    "default_premium_tee": 24.99,
    "default_tank": 21.99,
    "default_long_sleeve": 27.99
  },
  "colors": ["Black", "Navy", "Charcoal", "Dark Heather", "Royal Blue", "White"],
  "fits": ["Men", "Women", "Youth"],
  "brand": "Generic Brand",
  "tracker": {
    "db_path": "tracker/merch_tracker.db",
    "export_path": "tracker/dashboard_data.json"
  },
  "output_dir": "output",
  "images_dir": "images"
}
